model User {
  id            Int            @id @default(autoincrement())
  first_name    String
  last_name     String
  email         String         @unique
  password_hash String
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt
  posts         Post[]
  postLikes     PostLike[]
  comments      Comment[]
  commentLikes  CommentLike[]
  replies       Reply[]
  replyLikes    ReplyLike[]
}
